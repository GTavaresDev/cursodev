{
  "name": "curso",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && npm run migration:up && next dev",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:restart": "docker compose -f infra/compose.yaml restart",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:wait:database": "docker compose -f infra/compose.yaml exec -T database pg_isready -U postgres",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "commit": "cz",
    "test": "node infra/scripts/run-test-watch.js --ci",
    "test:ci": "node infra/scripts/run-test-watch.js --ci",
    "test:watch": "node infra/scripts/run-test-watch.js",
    "posttest": "npm run services:down",
    "migration:create": "node infra/create-migration.js",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migrations:create": "npm run migration:create",
    "migrations:up": "npm run migration:up",
    "prepare": "husky"
  },
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "next": "16.2.6",
    "next-connect": "1.0.0",
    "node-pg-migrate": "8.0.4",
    "pg": "8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "swr": "2.4.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "9.7.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "19.2.17",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "prettier": "3.8.3",
    "start-server-and-test": "3.0.5",
    "tailwindcss": "^4.3.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
